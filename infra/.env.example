# Docker Compose env (copy to infra/.env and fill secrets)
#
#   cp infra/.env.example infra/.env
#   cd infra && docker compose up --build
#
# Same machine:  http://localhost:3000/gateway/
# LAN / other PCs: http://<PUBLIC_HOST>:3000/gateway/
# Internet:        set NGROK_AUTHTOKEN, then check `docker compose logs ngrok`

# --- Required ---
SAFEZONE_DB_URI=mongodb+srv://USER:PASSWORD@HOST/safezone?retryWrites=true&w=majority
MALICIOUS_DB_URI=mongodb+srv://USER:PASSWORD@HOST/malicious?retryWrites=true&w=majority
JWT_SECRET=change-me
GATEWAY_JWT_SECRET=change-me
ADMIN_SOCKET_TOKEN=admin-secret
NEXT_PUBLIC_ADMIN_SOCKET_TOKEN=admin-secret

# --- LAN access (optional) ---
# Host Wi‑Fi IP — used in gateway logs and client URLs when opening from other devices
# PUBLIC_HOST=192.168.0.89
# NEXT_PUBLIC_TELEMETRY_SOCKET_URL=http://192.168.0.89:3000
# ADMIN_DASHBOARD_ORIGINS=http://192.168.0.89:3000

# --- Public tunnel (optional) ---
# NGROK_AUTHTOKEN=
