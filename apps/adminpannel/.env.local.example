# Copy to .env.local and fill secrets. Git ignores .env.local.

# --- Network (change one line) ---
# localhost = solo on this machine
# 192.168.x.x or Hamachi IP = others open http://<host>:3000/gateway/
DEV_PUBLIC_HOST=localhost

# Optional overrides (leave unset to derive from DEV_PUBLIC_HOST):
# UI_PORT=3000
# TELEMETRY_PORT=3002
# GATEWAY_PORT=4001
# NEXT_PUBLIC_TELEMETRY_SOCKET_URL=http://localhost:3002
# ADMIN_PANEL_URL=http://localhost:3000
# ADMIN_DASHBOARD_ORIGINS=http://localhost:3000
# GATEWAY_ORIGIN=http://127.0.0.1:4001

SAFEZONE_DB_URI=mongodb+srv://USER:PASS@HOST/DB?appName=Cluster0
MALICIOUS_DB_URI=mongodb+srv://USER:PASS@HOST/?appName=Cluster0

ADMIN_SOCKET_TOKEN=admin-secret
NEXT_PUBLIC_ADMIN_SOCKET_TOKEN=admin-secret

JWT_SECRET=dev-jwt-secret-change-me-please
GATEWAY_JWT_SECRET=dev-jwt-secret-change-me-please
ADMIN_TOTP_ENC_KEY_BASE64=
NODE_ENV=development
