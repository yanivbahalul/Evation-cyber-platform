# Copy to apps/admin-panel/.env (pnpm dev:full and Docker Compose)

SAFEZONE_DB_URI=mongodb+srv://USER:PASSWORD@HOST/safezone?retryWrites=true&w=majority
MALICIOUS_DB_URI=mongodb+srv://USER:PASSWORD@HOST/malicious?retryWrites=true&w=majority

JWT_SECRET=change-me-jwt-secret-min-32-chars
GATEWAY_JWT_SECRET=change-me-gateway-jwt-secret-min-32-chars
ADMIN_SOCKET_TOKEN=change-me-socket-token
NEXT_PUBLIC_ADMIN_SOCKET_TOKEN=change-me-socket-token

DEV_PUBLIC_HOST=localhost
TRUSTED_PROXY_IPS=127.0.0.1,::1

GATEWAY_ORIGIN=http://127.0.0.1:4001
NEXT_PUBLIC_TELEMETRY_SOCKET_URL=http://localhost:3002

TOTP_ISSUER_NAME=InnoTech Safe Zone
