# ML Threat-Intel service config (copy to .env for local runs)

# Port the FastAPI app listens on.
PORT=3003

# Shared secret — must match ADMIN_SOCKET_TOKEN used by the telemetry service.
ADMIN_SOCKET_TOKEN=admin-secret

# --- Model loading ---
# Master switch. Leave false for fast, dependency-light heuristic-only mode
# (CI, laptops, demos). Set true to download + run the Hugging Face models.
ML_ENABLE_MODELS=false

# Optional allowlist of model keys to load (default: all). Keys are:
# payload, payload_sqli_xss, log, mitre_tactic, attack_bert, secbert, cyber_groups
# ML_ENABLED_MODELS=payload,log,mitre_tactic,attack_bert

# Where Hugging Face caches weights (mount a volume in Docker to persist).
HF_HOME=/app/.hf-cache

# Only download safetensors weights (no pickle) — supply-chain hygiene.
HF_HUB_DISABLE_PROGRESS_BARS=1

LOG_LEVEL=INFO
