<% const title = 'InnoTech — Database Export' %>
<% const wb = typeof withBase === 'function' ? withBase : (p) => p %>
<%- include('../partials/head', { title, withBase: wb }) %>

<div class="container">
  <%- include('../partials/topbar', {
    user: typeof legacyUser !== 'undefined' ? legacyUser : null,
    brandTitle: 'InnoTech Administrator Services',
    brandSub: 'Legacy control plane',
    withBase: wb
  }) %>

  <div class="layout">
    <%- include('../partials/decoy-sidebar', { active: 'database', withBase: wb, legacyUser: typeof legacyUser !== 'undefined' ? legacyUser : null }) %>

    <main class="card">
      <div class="hero">
        <div class="kicker">Database services</div>
        <h2 style="margin: 0 0 8px;">users — export result</h2>
        <div class="muted">hr_finance replica · read-only dump · <%= rowCount %> rows</div>
      </div>

      <div class="card-inner">
        <div style="border:1px solid rgba(34,197,94,0.35); background: rgba(34,197,94,0.10); padding: 10px 12px; border-radius: 12px; margin-bottom: 14px;">
          <div style="font-weight:650;">Query completed</div>
          <div class="muted2" style="margin-top: 4px;">SELECT * FROM users — result set below (sensitive; internal use only).</div>
        </div>

        <table class="table">
          <thead>
            <tr>
              <th>id</th>
              <th>username</th>
              <th>password</th>
              <th>password_hash</th>
              <th>role</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(r => { %>
            <tr>
              <td class="muted2"><%= r.id %></td>
              <td><%= r.username %></td>
              <td><code style="font-size:12px;"><%= r.password %></code></td>
              <td class="muted2" style="font-size:11px; word-break:break-all;"><%= r.hash %></td>
              <td><span class="badge"><%= r.role %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>

        <%- include('../partials/decoy-kill-chain', { withBase: wb, dp: typeof dp !== 'undefined' ? dp : {} }) %>
        <div class="btn-row" style="margin-top: 14px;">
          <a class="btn primary" href="<%= wb((typeof dp !== 'undefined' && dp.database) || '/internal/services/database') %>">Run another query</a>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('../partials/foot') %>
