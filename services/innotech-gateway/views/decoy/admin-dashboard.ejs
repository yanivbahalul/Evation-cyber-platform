<% const title = (company || 'InnoTech') + ' — Administrator Console' %>
<% const wb = typeof withBase === 'function' ? withBase : (p) => p %>
<%- include('../partials/head', { title, withBase: wb }) %>

<div class="container">
  <%- include('../partials/topbar', {
    user: typeof user !== 'undefined' ? user : null,
    withBase: wb,
    brandTitle: 'InnoTech Administrator Services',
    brandSub: 'Legacy control plane',
    accessLabel: 'Operator',
    accessDetail: 'console access'
  }) %>

  <div class="layout">
    <%- include('../partials/decoy-sidebar', { active: 'console', withBase: wb, legacyUser: typeof user !== 'undefined' ? user : null }) %>

    <main class="card">
      <div class="hero">
        <div class="kicker">Legacy administrator zone</div>
        <h2 style="margin: 0 0 8px;"><%= company %> · Console</h2>
        <div class="muted">Internal HR and finance snapshot · read-only</div>
      </div>

      <div class="card-inner">
        <% if (typeof breachFlash !== 'undefined' && breachFlash) { %>
          <div style="border:1px solid rgba(34,197,94,0.35); background: rgba(34,197,94,0.10); padding: 12px 14px; border-radius: 12px; margin-bottom: 14px;">
            <div style="font-weight:650;">Authentication successful</div>
            <div class="muted2" style="margin-top: 4px;">
              Legacy break-glass channel accepted credentials for <strong><%= breachUsername %></strong>.
              Elevated administrator session is active — full console access granted.
            </div>
          </div>
        <% } %>
        <% if (typeof tokenAck !== 'undefined' && tokenAck) { %>
          <div style="border:1px solid rgba(14,165,165,0.35); background: rgba(14,165,165,0.10); padding: 12px 14px; border-radius: 12px; margin-bottom: 14px;">
            <div style="font-weight:650;">API token validated</div>
            <div class="muted2" style="margin-top: 4px;">Integration key accepted — elevated console session granted.</div>
          </div>
        <% } %>

        <% if (typeof breachFlash !== 'undefined' && breachFlash || typeof tokenAck !== 'undefined' && tokenAck) { %>
          <%- include('../partials/decoy-kill-chain', { withBase: wb, dp: typeof dp !== 'undefined' ? dp : {} }) %>
        <% } %>

        <div class="grid-4">
          <div class="stat">
            <div class="label">Employees</div>
            <div class="value"><%= stats.totalEmployees %></div>
          </div>
          <div class="stat">
            <div class="label">Revenue</div>
            <div class="value"><%= stats.revenue %></div>
          </div>
          <div class="stat">
            <div class="label">Open tickets</div>
            <div class="value"><%= stats.openTickets %></div>
          </div>
          <div class="stat">
            <div class="label">Uptime</div>
            <div class="value"><%= stats.uptime %></div>
          </div>
        </div>

        <div style="height: 14px;"></div>

        <div class="btn-row">
          <a class="btn primary" href="<%= wb('/documents?download=backup.zip') %>">Download full backup (ZIP)</a>
          <a class="btn" href="<%= wb((typeof dp !== 'undefined' && dp.apiKeys) || '/internal/integrations/keys') %>">API integration keys</a>
          <% if (!(typeof user !== 'undefined' && user)) { %>
          <a class="btn" href="<%= wb((typeof dp !== 'undefined' && dp.legacySignIn) || '/internal/auth/legacy') %>">Legacy sign-in</a>
          <% } %>
        </div>

        <div style="height: 14px;"></div>

        <table class="table">
          <thead>
            <tr>
              <th>Name</th><th>Email</th><th>Department</th>
              <th>Role</th><th>Joined</th><th>Salary</th>
            </tr>
          </thead>
          <tbody>
            <% employees.forEach(e => { %>
              <tr>
                <td><%= e.name %></td>
                <td><%= e.email %></td>
                <td><%= e.department %></td>
                <td><%= e.role %></td>
                <td><%= e.joined %></td>
                <td>$<%= e.salary.toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="muted2" style="margin-top: 14px; font-size: 12px;">
          Generated <%= generated %> · admin@innotech.io · v4.12.0
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('../partials/foot') %>
