<% const title = 'InnoTech — Support Ticket Saved' %>
<% const wb = typeof withBase === 'function' ? withBase : (p) => p %>
<% const xssTier = typeof tier !== 'undefined' ? tier : 'blocked' %>
<%- include('../partials/head', { title, withBase: wb }) %>

<div class="container">
  <%- include('../partials/topbar', { user: null }) %>

  <div class="layout">
    <%- include('../partials/sidebar', { user: null, active: 'home', adminPanelUrl: 'http://localhost:3000', withBase: wb }) %>

    <main class="card">
      <div class="hero">
        <div class="kicker">IT Support</div>
        <h2 style="margin: 0 0 8px;">Ticket received</h2>
        <div class="muted">Your submission was stored for moderation review.</div>
      </div>

      <div class="card-inner">
        <div class="badge ok" style="margin-bottom: 12px;">Ticket #<%= typeof ticketId !== 'undefined' ? ticketId : ('IT-' + Date.now().toString(36).toUpperCase()) %> — queued for review</div>

        <% if (xssTier === 'probe' && reflectPayload) { %>
          <div class="badge warn" style="margin-bottom: 12px;">Live preview (unmoderated queue)</div>
          <h3 style="margin: 0 0 8px; font-size: 15px;">Rendered preview</h3>
          <div id="xss-reflection" class="input" style="min-height: 48px; margin: 0 0 12px; padding: 12px;"><%- reflectPayload %></div>
          <h3 style="margin: 0 0 8px; font-size: 15px;">Stored copy (escaped)</h3>
          <pre class="input" style="white-space: pre-wrap; word-break: break-all; margin: 0 0 12px; font-size: 13px;"><%= payload %></pre>
        <% } else { %>
          <div class="badge" style="margin-bottom: 12px; background: #e0e7ff; color: #3730a3;">Content sanitized — submission quarantined</div>
          <% if (blockedReason) { %>
            <div class="muted2" style="font-size: 13px; margin-bottom: 8px;">Moderation rule: <%= blockedReason %></div>
          <% } %>
          <h3 style="margin: 0 0 8px; font-size: 15px;">Preview (escaped)</h3>
          <pre class="input" style="white-space: pre-wrap; word-break: break-all; margin: 0 0 12px; font-size: 13px;"><%= payload %></pre>
        <% } %>

        <div class="muted2" style="font-size: 13px;">
          Submitted <%= savedAt %> · <%= byteLen %> bytes · stored in moderation queue.
        </div>

        <div class="btn-row" style="margin-top: 14px;">
          <a class="btn primary" href="<%= wb('/contact') %>">Submit another ticket</a>
          <a class="btn" href="<%= wb('/') %>">Home</a>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('../partials/foot') %>
