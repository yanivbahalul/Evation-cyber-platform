<% const title = 'InnoTech — Internal Access' %>
<% const wb = typeof withBase === 'function' ? withBase : (p) => p %>
<%- include('partials/head', { title, withBase: wb }) %>

<div class="container">
  <%- include('partials/topbar', {
    user: null,
    brandTitle: 'InnoTech Administrator Services',
    brandSub: 'Legacy control plane',
    accessLabel: 'Restricted',
    accessDetail: 'routing'
  }) %>
  <div class="layout">
    <%- include('partials/decoy-sidebar', { active: 'console', withBase: wb }) %>
    <main class="card">
      <div class="hero">
        <div class="kicker">Internal routing</div>
        <h2 style="margin: 0 0 8px;">Administrator console</h2>
        <div class="muted">Loading legacy control plane…</div>
      </div>
      <div class="card-inner">
        <a class="btn primary" href="<%= wb((typeof dp !== 'undefined' && dp.console) || '/internal/console') %>">Continue to console</a>
      </div>
    </main>
  </div>
</div>

<%- include('partials/foot') %>
