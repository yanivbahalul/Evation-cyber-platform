<% const title = 'InnoTech — IT Support' %>
<%- include('partials/head', { title }) %>

<div class="container">
  <%- include('partials/topbar', { user }) %>

  <div class="layout">
    <%- include('partials/sidebar', { user, active: 'home', adminPanelUrl }) %>

    <main class="card">
      <div class="hero">
        <div class="kicker">Support</div>
        <h2 style="margin: 0 0 8px;">Contact IT Support</h2>
        <div class="muted">Submit a ticket — processed by the internal helpdesk queue.</div>
      </div>

      <div class="card-inner">
        <% if (success) { %>
          <div class="badge ok" style="margin-bottom: 12px;">Ticket received — reference will be emailed shortly</div>
        <% } %>
        <% if (formError) { %>
          <div class="badge" style="margin-bottom: 12px; background: #fee2e2; color: #991b1b;"><%= formError %></div>
        <% } %>
        <form class="form" method="POST" action="<%= withBase('/contact') %>">
          <input class="input" name="subject" placeholder="Subject (e.g. VPN access request)" value="<%= typeof subject !== 'undefined' ? subject : '' %>" required />
          <textarea class="input" name="message" rows="5" placeholder="Describe the issue..." required><%= typeof message !== 'undefined' ? message : '' %></textarea>
          <button class="btn primary" type="submit" style="width: 100%;">Submit ticket</button>
        </form>

        <div class="muted2" style="margin-top: 12px; font-size: 13px;">
          Emergency: call internal extension <strong>1337</strong>.
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/foot') %>
