<% const title = 'InnoTech — Documents' %>
<%- include('partials/head', { title }) %>

<div class="container">
  <%- include('partials/topbar', { user }) %>

  <div class="layout">
    <%- include('partials/sidebar', { user, active: 'documents', adminPanelUrl }) %>

    <main class="card">
      <div class="hero">
        <div class="kicker">Library</div>
        <h2 style="margin: 0 0 8px;">Documents</h2>
        <div class="muted">Internal documents and forms · HR &amp; compliance</div>
      </div>

      <div class="card-inner">
        <table class="table">
          <thead>
            <tr><th>Name</th><th>Type</th><th>Updated</th><th>Access</th></tr>
          </thead>
          <tbody>
            <% if (!documents.length) { %>
              <tr>
                <td colspan="4" class="muted2">No documents in the library yet.</td>
              </tr>
            <% } %>
            <% documents.forEach(d => { %>
              <tr>
                <td><%= d.name %></td>
                <td><span class="badge"><%= d.type %></span></td>
                <td class="muted2"><%= d.updated %></td>
                <td>
                  <a class="btn" href="<%= withBase('/documents/' + encodeURIComponent(d.name)) %>">View</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</div>

<%- include('partials/foot') %>

